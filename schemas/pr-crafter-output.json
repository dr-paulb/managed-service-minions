{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "branch": { "type": "string" },
    "pr_url": { "type": "string" },
    "pr_number": { "type": ["integer", "string"] },
    "commits": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "linked_ticket": { "type": "string" }
  },
  "required": ["branch", "pr_url", "files_changed"]
}
