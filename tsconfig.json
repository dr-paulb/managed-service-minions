{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "framework-core": ["./packages/framework-core/src/index.ts"],
      "mcp-toolshed": ["./extensions/mcp-toolshed/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "extensions/**/*.ts", "infra/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage", "**/__tests__", "**/*.test.ts"]
}
