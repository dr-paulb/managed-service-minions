{
  "name": "test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Test harness for the Goose Agent Framework.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --testPathPattern integration",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --testPathPattern e2e"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.17",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "mcp-toolshed": "workspace:*",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "framework-core": "workspace:*"
  }
}
